# ═══ DATABASE ═══
# Local Development: Use your cloud PostgreSQL connection string
# Example (Vercel Postgres): postgres://default:...@...postgres.vercel-storage.com:5432/verceldb
# Example (Supabase): postgresql://postgres:[password]@db.xxx.supabase.co:5432/postgres
# Example (Neon): postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb
DATABASE_URL="postgresql://username:password@localhost:5432/nexusrevive?schema=public"

# Direct database URL (non-pooled, required for migrations)
# For Vercel Postgres, use POSTGRES_URL_NON_POOLING from Vercel dashboard
DIRECT_DATABASE_URL="postgresql://username:password@localhost:5432/nexusrevive?schema=public"

# ═══ AUTH ═══
NEXTAUTH_SECRET="replace-with-64-char-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ═══ POLAR.SH MONETIZATION ═══
NEXT_PUBLIC_POLAR_CHECKOUT_URL="https://buy.polar.sh/your-checkout-id"
POLAR_ORG_ID="your-polar-org-id"
POLAR_WEBHOOK_SECRET="your-polar-webhook-secret"
POLAR_ACCESS_TOKEN="your-polar-api-access-token"
POLAR_PRODUCT_ID="your-polar-product-id"

# ═══ CRON ═══
CRON_SECRET="your-cron-secret"

# ═══ FILE STORAGE ═══
STORAGE_PATH="./storage"
TEMP_PATH="./storage/tmp"
OUTPUT_PATH="./storage/output"
AI_MODELS_PATH="./storage/ai-models"
MAX_FREE_FILE_BYTES="26214400"
MAX_PRO_FILE_BYTES="524288000"
FILE_EXPIRY_HOURS="24"
MAX_FREE_JOBS_PER_DAY="10"
MAX_BATCH_FILES_PRO="50"

# ═══ LOCAL AI ═══
ENABLE_LOCAL_AI="true"
ENABLE_OCR="true"
AI_MODEL_CACHE="true"

# ═══ APP ═══
NEXT_PUBLIC_APP_NAME="Nexus Revive"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_VERSION="1.0.0"
NODE_ENV="development"
