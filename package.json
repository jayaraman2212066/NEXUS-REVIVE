    "@radix-ui/react-switch": "1.1.0",
    "@radix-ui/react-tabs": "1.1.0",
    "@radix-ui/react-toast": "1.2.1",
    "@tsparticles/react": "3.0.0",
    "@tsparticles/slim": "3.3.0",
    "@types/bcryptjs": "2.4.6",
    "@types/dompurify": "3.0.5",
    "@types/formidable": "3.4.5",
    "@types/node": "22.1.0",
