{
  "name": "nexus-revive",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/verify-build.js && prisma generate && next build",
    "start": "next start",
    "postinstall": "node scripts/postinstall.js && prisma generate",
    "lint": "next lint && prettier --check .",
    "format": "prettier --write .",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-reviews": "tsx prisma/seed-reviews.ts",
    "docker:up": "docker-compose up --build -d",
    "docker:down": "docker-compose down",
    "test": "vitest",
    "test:e2e": "playwright test",
    "setup": "npm install && npm run db:push && echo ✅ Nexus Revive ready! Run: npm dev",
    "verify": "node scripts/verify-build.js",
    "pre-deploy": "node scripts/verify-build.js"
  },
  "dependencies": {
    "@prisma/client": "5.17.0",
    "@radix-ui/react-dialog": "1.1.1",
